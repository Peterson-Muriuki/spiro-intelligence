### faker.providers.date_time

	fake.am_pm()                                                                # PM
	fake.century()                                                              # IV
	fake.date(pattern='%Y-%m-%d', end_datetime=None)                            # 1985-07-07
	fake.date_between(start_date='-30y', end_date='today')                      # 2018-10-26
	fake.date_between_dates(date_start=None, date_end=None)                     # 2026-03-17
	fake.date_object(end_datetime=None)                                         # 2001-01-28
	fake.date_of_birth(tzinfo=None, minimum_age=0, maximum_age=115)             # 1934-04-04
	fake.date_this_century(before_today=True, after_today=False)                # 2023-07-28
	fake.date_this_decade(before_today=True, after_today=False)                 # 2020-01-21
	fake.date_this_month(before_today=True, after_today=False)                  # 2026-03-16
	fake.date_this_year(before_today=True, after_today=False)                   # 2026-02-09
	fake.date_time(tzinfo=None, end_datetime=None)                              # 2001-07-10 06:38:48
	fake.date_time_ad(tzinfo=None, end_datetime=None, start_datetime=None)      # 0079-02-13 21:10:25
	fake.date_time_between(start_date='-30y', end_date='now', tzinfo=None)      # 2012-06-09 18:58:52
	fake.date_time_between_dates(datetime_start=None, datetime_end=None,        # 2026-03-17 12:48:06
	  tzinfo=None)                                                              
	fake.date_time_this_century(before_now=True, after_now=False, tzinfo=None)  # 2010-02-01 19:12:11
	fake.date_time_this_decade(before_now=True, after_now=False, tzinfo=None)   # 2026-01-01 19:47:52
	fake.date_time_this_month(before_now=True, after_now=False, tzinfo=None)    # 2026-03-05 05:53:38
	fake.date_time_this_year(before_now=True, after_now=False, tzinfo=None)     # 2026-02-18 20:49:33
	fake.day_of_month()                                                         # 12
	fake.day_of_week()                                                          # Monday
	fake.future_date(end_date='+30d')                                           # 2026-04-03
	fake.future_datetime(end_date='+30d', tzinfo=None)                          # 2026-04-15 07:32:09
	fake.iso8601(tzinfo=None, end_datetime=None, sep='T', timespec='auto')      # 2012-11-10T05:10:44
	fake.month()                                                                # 03
	fake.month_name()                                                           # October
	fake.past_date(start_date='-30d', tzinfo=None)                              # 2026-02-25
	fake.past_datetime(start_date='-30d', tzinfo=None)                          # 2026-02-28 01:57:17
	fake.pytimezone(*args, **kwargs)                                            # America/Costa_Rica
	fake.time(pattern='%H:%M:%S', end_datetime=None)                            # 21:56:13
	fake.time_delta(end_datetime=None)                                          # 0:00:00
	fake.time_object(end_datetime=None)                                         # 09:34:50
	fake.time_series(start_date='-30d', end_date='now', precision=None,         # <generator object Provider.time_series at 0x000002155D971D80>
	  distrib=None, tzinfo=None)                                                
	fake.timezone()                                                             # Africa/Maseru
	fake.unix_time(end_datetime=None, start_datetime=None)                      # 727977670.0
	fake.year()                                                                 # 1986

