	fake.random_digit_above_two()                                               # 8
	fake.random_digit_not_null()                                                # 5
	fake.random_digit_not_null_or_empty()                                       
	fake.random_digit_or_empty()                                                
	fake.random_element(elements=('a', 'b', 'c'))                               # a
